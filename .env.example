# Perch environment template (Person B leads: FOUNDATION-CONTRACT section 6 item 3).
# Copy to `.env.local` and fill in. NEVER commit a real .env file.
# Server-only secrets MUST NOT use the NEXT_PUBLIC_ prefix (that would ship them to
# the client bundle). Only the three values explicitly marked PUBLIC below are safe there.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=            # PUBLIC: project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # PUBLIC: anon key (RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=           # SECRET: server-only, bypasses RLS. Never NEXT_PUBLIC_.
NEXT_PUBLIC_DATA_SOURCE=fixture      # fixture or live
DEV_DEMO_USER_ID=                    # local API fallback only; real acceptance uses /login cookies

# --- OpenAI (via Vercel AI SDK): narration only ---
OPENAI_API_KEY=                      # SECRET
OPENAI_MODEL=gpt-4o-mini             # cheap model for dev
LLM_DISABLED=0                       # set 1 to force deterministic-only (no prose) everywhere
LIVE_LLM=0                           # set 1 only when intentionally running the paid narration smoke test

# --- Mapbox (Person A renders; token here for completeness) ---
NEXT_PUBLIC_MAPBOX_TOKEN=            # PUBLIC: map render token

# --- Composio (Spotify + IG Business OAuth) ---
COMPOSIO_API_KEY=                    # SECRET
COMPOSIO_DISABLED=0                  # set 1 to force the fixture taste-vector fallback (B5)
COMPOSIO_SPOTIFY_AUTH_CONFIG_ID=     # Spotify OAuth config with user-top-read only
COMPOSIO_SPOTIFY_CALLBACK_URL=       # optional callback after hosted OAuth

# --- Spotify (fallback hand-written OAuth if Composio spike fails) ---
SPOTIFY_CLIENT_ID=                   # server configuration
SPOTIFY_CLIENT_SECRET=               # SECRET

# --- Google Calendar (optional itinerary sync, B8) ---
GOOGLE_CLIENT_ID=                    # server configuration
GOOGLE_CLIENT_SECRET=                # SECRET

# --- Ticketmaster (Person C event integration) ---
TICKETMASTER_API_KEY=                # SECRET

# --- Cron / scheduled jobs (RB51/RB52; server-only, never NEXT_PUBLIC_) ---
CRON_SECRET=                         # SECRET: guards /api/cron/* on Vercel. Vercel Cron sends it as
                                     #   `Authorization: Bearer <value>`. Unset = dev-open, prod-closed.
REFRESH_COOLDOWN_MS=                 # optional: on-request event-refresh cooldown per city (default 6h)

# --- Rate limiting (B12) ---
RATE_LIMIT_WINDOW_MS=60000           # sliding window size
RATE_LIMIT_MAX=20                    # max requests per window per caller/IP

# --- Provisioning / ops (Round 4 RB41; server-only, never NEXT_PUBLIC_) ---
SUPABASE_DB_URL=                     # SECRET: direct Postgres URL (incl. password) for db:push / RLS.
                                     #   Hosted: postgres://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=               # SECRET: optional, only if using the Supabase CLI (supabase link/db push)

# --- RLS test harness + local seed (local only) ---
RLS_TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
RUN_RLS_TESTS=0
SEED_DIRECT_DB_URL=                  # LOCAL-only: target Postgres for `npm run seed:local` (scripts/seed-direct.ts)
# --- Live auth acceptance (local only; tests/auth-live.test.ts) ---
AUTH_TEST_SUPABASE_URL=              # PUBLIC value, test-only: project URL for the live login smoke test
AUTH_TEST_SUPABASE_ANON_KEY=         # PUBLIC value, test-only: anon key for the live login smoke test
RUN_AUTH_TESTS=0
