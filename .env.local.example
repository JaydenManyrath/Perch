# Optional client-only quick-start template. `.env.example` is the complete source
# of truth for local setup. Copy that file when running live APIs, seed, or RLS.
# Real secrets live in .env.local (gitignored) and must NEVER use NEXT_PUBLIC_.

# Data source: "fixture" (default) makes the app fully demoable with zero live keys.
# Set to "live" to hit real Person-B API routes + Supabase.
NEXT_PUBLIC_DATA_SOURCE=fixture

# Supabase public URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox public token, client-visible by design.
NEXT_PUBLIC_MAPBOX_TOKEN=
