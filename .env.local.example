# Perch — client-visible env only. Real secrets live in .env.local (gitignored).
# Person A holds only these two client-visible keys per CLAUDE.md §8.4.
# Server-side keys (OpenAI, Composio, Supabase service-role) belong to Person B and
# must NEVER be NEXT_PUBLIC_.

# Data source: "fixture" (default) makes the app fully demoable with zero live keys.
# Set to "live" to hit real Person-B API routes + Supabase.
NEXT_PUBLIC_DATA_SOURCE=fixture

# Supabase (Person A holds only the anon/publishable key + URL — service-role is Person B).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox — public token, client-visible by design.
NEXT_PUBLIC_MAPBOX_TOKEN=
